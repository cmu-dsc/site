		<script>
			// Create floating card suit particles
			function createParticle() {
				const particles = document.getElementById('particles');
				if (!particles) return;

				const suits = ['♠', '♥', '♣', '♦'];
				const colors = ['rgba(255, 51, 51, 0.15)', 'rgba(255, 51, 51, 0.1)', 'rgba(255, 255, 255, 0.1)'];

				const particle = document.createElement('div');
				const suit = suits[Math.floor(Math.random() * suits.length)];
				const color = colors[Math.floor(Math.random() * colors.length)];

				particle.textContent = suit;
				particle.style.position = 'absolute';
				particle.style.fontSize = `${Math.random() * 2 + 1}rem`;
				particle.style.color = color;
				particle.style.left = `${Math.random() * 100}%`;
				particle.style.top = `${Math.random() * 100}%`;
				particle.style.pointerEvents = 'none';
				particle.style.userSelect = 'none';

				const duration = Math.random() * 10 + 15;
				const xMove = (Math.random() - 0.5) * 200;
				const yMove = -(Math.random() * 150 + 50);

				particle.style.animation = `particleFloat ${duration}s linear infinite`;
				particle.style.setProperty('--x-move', `${xMove}px`);
				particle.style.setProperty('--y-move', `${yMove}px`);
				particle.style.animationDelay = `${Math.random() * 5}s`;

				particles.appendChild(particle);

				// Limit total particles
				if (particles.children.length > 15) {
					particles.removeChild(particles.children[0]);
				}
			}

			// Create initial particles
			for (let i = 0; i < 12; i++) {
				setTimeout(createParticle, i * 500);
			}

			// Add new particles periodically
			setInterval(createParticle, 3000);
		</script>
	</body>
</html>